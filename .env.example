# ===== LOCAL DEVELOPMENT =====
DATABASE_URL="file:./prisma/dev.db"

# ===== NEXTAUTH =====
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"   # ganti ke domain asli di production

# ===== TURSO (production database) =====
# Daftar gratis di https://turso.tech
# Install CLI: brew install tursodatabase/tap/turso
# turso auth login
# turso db create amrt-dev
# turso db show amrt-dev          -> copy URL
# turso db tokens create amrt-dev -> copy token
TURSO_DATABASE_URL="libsql://your-db-name.turso.io"
TURSO_AUTH_TOKEN="your-turso-auth-token"

# ===== CLOUDINARY (image uploads) =====
# Daftar gratis di https://cloudinary.com
# Dashboard -> API Keys
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
